# Node.js dev environment in a hardware-isolated microVM
#
#   smolvm sandbox run -s examples/node-app/node.smolfile
#   smolvm microvm create dev -s node.smolfile
#   smolvm microvm start dev
#   smolvm microvm exec --name dev -- node -e "console.log('hello')"

image = "node:22-alpine"
entrypoint = ["node"]

cpus = 2
memory = 512
net = true

[dev]
ports = ["3000:3000"]
init = ["npm install -g nodemon"]
