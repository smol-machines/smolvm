{
  "name": "smolvm-embedded",
  "version": "0.1.0",
  "description": "Embedded Node.js SDK for smolvm",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "optionalDependencies": {
    "smolvm-embedded-darwin-arm64": "0.1.0",
    "smolvm-embedded-darwin-x64": "0.1.0",
    "smolvm-embedded-linux-arm64-gnu": "0.1.0",
    "smolvm-embedded-linux-x64-gnu": "0.1.0"
  },
  "license": "Apache-2.0"
}
